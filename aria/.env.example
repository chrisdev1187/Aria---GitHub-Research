# ============================================================
# ARIA v2 — Agentic Research Intelligence Architecture
# Provider API Keys & Configuration
# ============================================================
# Copy this file to .env and fill in your keys.
# At minimum, set GROQ_API_KEY and GITHUB_TOKEN for the pipeline to run.

# === GROQ (supports up to 4 keys — primary fast inference) ===
# Get keys: https://console.groq.com/keys
# Multiple keys: GROQ_API_KEY=key1,key2,key3,key4
GROQ_API_KEY=

# === DEEPSEEK (supports up to 2 keys — code analysis) ===
# Get keys: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# === SAMBANOVA (supports up to 2 keys — synthesis fallback) ===
# Get keys: https://cloud.sambanova.ai/apis
SAMBANOVA_API_KEY=

# === SILICONFLOW (supports up to 2 keys — web research + general fallback) ===
# Get keys: https://cloud.siliconflow.cn/account/ak
SILICONFLOW_API_KEY=

# === NVIDIA NIM (supports up to 2 keys — primary synthesizer) ===
# Get keys: https://build.nvidia.com/explore/discover
NVIDIA_API_KEY=

# === CEREBRAS (1 key — circuit breaker hot path) ===
# Get keys: https://console.cerebras.ai/
CEREBRAS_API_KEY=

# === ZHIPU (1 key — final fallback) ===
# Get keys: https://open.bigmodel.cn/
ZHIPU_API_KEY=

# === GEMINI (1 key — large file context reader ONLY) ===
# Get keys: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# === INFRASTRUCTURE ===
GITHUB_TOKEN=
JINA_API_KEY=

# === OLLAMA (local — no key) ===
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=qwen2.5:3b-instruct-q4_K_M
OLLAMA_DEEP_MODEL=qwen2.5-coder:7b-q4_K_M

# === RESEARCH CONFIG ===
MAX_REPOS_PER_SUBPROBLEM=10
MAX_FILES_PER_REPO=5
MAX_RESEARCH_LOOPS=2
MAX_SUBPROBLEMS=7
MAX_CONCURRENT_AGENTS=3
ENABLE_WEB_RESEARCH=true
ENABLE_HUMAN_CHECKPOINT=true
